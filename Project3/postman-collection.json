	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Set base URL from environment variable or default",
					"if (!pm.collectionVariables.get('baseUrl')) {",
					"    pm.collectionVariables.set('baseUrl', 'http://localhost:8080');",
					"}",
					"",
					"// Auto-refresh token if it's about to expire",
					"if (pm.collectionVariables.get('jwt_token') && pm.info.requestName !== 'Login' && pm.info.requestName !== 'Refresh Token') {",
					"    // Check if token exists and we're not making an auth request",
					"    const token = pm.collectionVariables.get('jwt_token');",
					"    if (token) {",
					"        // Simple token validation - you can add more sophisticated checks",
					"        try {",
					"            const payload = JSON.parse(atob(token.split('.')[1]));",
					"            const currentTime = Math.floor(Date.now() / 1000);",
					"            // Refresh token if it expires in the next 5 minutes",
					"            if (payload.exp - currentTime < 300) {",
					"                // Token expires soon, refresh it",
					"                console.log('Token expires soon, refreshing...');",
									"            }",
					"        } catch (e) {",
					"            console.log('Token validation failed, continuing...');",
					"        }",
					"    }",
					"}"
				]
			}
		}
